# =============================================================================
# CoreCart environment variables
# Copy this file to `.env` (local) and set the same keys in your host's
# dashboard (Render / Vercel). Nothing here is required to run locally — the
# app degrades gracefully when a value is missing.
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND (the Express server — e.g. Render)
# -----------------------------------------------------------------------------

# Optional. Enables real AI text generation via NVIDIA's OpenAI-compatible API
# (build.nvidia.com / NIM). Without it, the app uses free heuristics, so it
# still works fully. Images are always rendered with Pollinations (NVIDIA's
# models are text-only).
NVIDIA_API_KEY="YOUR_API_KEY_HERE"

# The NVIDIA model to use for text generation. Defaults to meta/llama-3.3-70b-instruct.
NVIDIA_MODEL="meta/llama-3.3-70b-instruct"

# Optional. Override the NVIDIA API base URL. Defaults to https://integrate.api.nvidia.com/v1
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# Set automatically by most hosts (Render injects it). Locally defaults to 3000.
# Do NOT hard-code this to 3000 on Render.
# PORT=3000

# Set to "production" on your live backend so it serves the built frontend
# and uses production static asset handling.
NODE_ENV="production"

# Comma-separated list of the EXACT frontend origins allowed to call this API.
# Required for a split deploy (frontend on Vercel, backend on Render) so the
# browser's CORS check passes. Leave empty to allow any origin ("*").
# Example: ALLOWED_ORIGINS="https://my-store.vercel.app,https://www.mydomain.com"
ALLOWED_ORIGINS=""

# Optional. Point these at a Postgres/Neon database to persist data across
# restarts/deploys. If SQL_HOST is unset, the app uses a local db.json file.
SQL_HOST=""
SQL_USER=""
SQL_PASSWORD=""
SQL_DB_NAME=""

# -----------------------------------------------------------------------------
# FRONTEND (the Vite build — e.g. Vercel)  — must be prefixed with VITE_
# -----------------------------------------------------------------------------

# The public URL of your backend. When set at build time, every "/api/..."
# request from the frontend is sent to this URL instead of the frontend's own
# origin. Required ONLY for a split deploy. Leave empty for the all-in-one
# deploy (frontend + backend served by the same server).
# Example: VITE_API_BASE_URL="https://corecart-backend.onrender.com"
VITE_API_BASE_URL=""
